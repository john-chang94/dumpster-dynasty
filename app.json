{
  "expo": {
    "name": "dumpster-dynasty",
    "slug": "dumpster-dynasty",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/sliced/portraits/raccoon_scout_portrait.png",
    "scheme": "dumpsterdynasty",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8E8CA",
        "foregroundImage": "./assets/sliced/portraits/raccoon_scout_portrait.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/sliced/portraits/raccoon_scout_portrait.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/sliced/portraits/raccoon_scout_portrait.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8E8CA",
          "dark": {
            "backgroundColor": "#2D2118"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
